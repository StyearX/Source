-- Store slot configurations
local slotConfigs = {}

-- Function to get emotes folder
local function getEmotesFolder()
    local items = RS:FindFirstChild("Items")
    if items then
        return items:FindFirstChild("Emotes")
    end
    return nil
end

-- Function to swap emote
local function swapEmote(slotNumber, currentEmote, swapWithEmote)
    if currentEmote == "" or swapWithEmote == "" then
        Fluent:Notify({
            Title = "Error",
            Content = "Both fields must be filled!",
            Duration = 3
        })
        return false
    end
    
    if currentEmote == swapWithEmote then
        Fluent:Notify({
            Title = "Error",
            Content = "Current and Swap emotes cannot be the same!",
            Duration = 3
        })
        return false
    end
    
    local emotesFolder = getEmotesFolder()
    if not emotesFolder then
        Fluent:Notify({
            Title = "Error",
            Content = "Emotes folder not found!",
            Duration = 3
        })
        return false
    end
    
    local targetEmote = nil  -- The emote to rename (swapWith)
    local sourceEmote = nil  -- The emote we own (currentEmote)
    
    for _, obj in ipairs(emotesFolder:GetDescendants()) do
        if obj:IsA("ModuleScript") then
            if obj.Name == swapWithEmote then
                targetEmote = obj
            elseif obj.Name == currentEmote then
                sourceEmote = obj
            end
        end
    end
    
    if targetEmote and sourceEmote then
        targetEmote.Name = currentEmote
        
        Fluent:Notify({
            Title = "Slot " .. slotNumber,
            Content = string.format("Swapped '%s' with '%s'", swapWithEmote, currentEmote),
            Duration = 4
        })
        return true
    else
        local missing = {}
        if not targetEmote then table.insert(missing, swapWithEmote) end
        if not sourceEmote then table.insert(missing, currentEmote) end
        
        Fluent:Notify({
            Title = "Error",
            Content = string.format("Could not find: %s", table.concat(missing, ", ")),
            Duration = 4
        })
        return false
    end
end

-- Create 6 emote slots
local sections = {}
local currentInputs = {}
local swapInputs = {}

for slot = 1, 6 do
    local section = EmoteTab:AddSection(string.format("━━━ Slot %d ━━━", slot))
    sections[slot] = section
    
    -- Store input values
    slotConfigs[slot] = {
        current = "",
        swap = ""
    }
    
    -- Current emote input
    currentInputs[slot] = section:AddInput(string.format("Slot%d_Current", slot), {
        Title = "Current Emote (One I Have)",
        Description = "Enter the name of the emote you own",
        Default = "",
        Placeholder = "e.g., Stride, Dance, Wave",
        Numeric = false,
        Finished = false
    })
    
    currentInputs[slot]:OnChanged(function(value)
        slotConfigs[slot].current = value
    end)
    
    -- Swap with emote input
    swapInputs[slot] = section:AddInput(string.format("Slot%d_Swap", slot), {
        Title = "Swap With Emote",
        Description = "Enter the name of the emote to transform",
        Default = "",
        Placeholder = "e.g., Broom, Point, Laugh",
        Numeric = false,
        Finished = false
    })
    
    swapInputs[slot]:OnChanged(function(value)
        slotConfigs[slot].swap = value
    end)
    
    -- Apply button
    section:AddButton({
        Title = string.format("Apply Slot %d", slot),
        Description = "Execute emote swap for this slot",
        Callback = function()
            swapEmote(slot, slotConfigs[slot].current, slotConfigs[slot].swap)
        end
    })
    
    -- Divider after each slot (except last)
    if slot < 6 then
        section:AddDivider()
    end
end

-- Add Quick Actions section
local QuickSection = EmoteTab:AddSection("━━━ Quick Actions ━━━")

-- Reset all slots button
QuickSection:AddButton({
    Title = "Reset All Slots",
    Description = "Clear all slot configurations",
    Callback = function()
        for slot = 1, 6 do
            slotConfigs[slot].current = ""
            slotConfigs[slot].swap = ""
            
            -- Update input fields if possible
            if currentInputs[slot] and currentInputs[slot].SetValue then
                currentInputs[slot]:SetValue("")
            end
            if swapInputs[slot] and swapInputs[slot].SetValue then
                swapInputs[slot]:SetValue("")
            end
        end
        
        Fluent:Notify({
            Title = "Reset Complete",
            Content = "All slots have been cleared",
            Duration = 3
        })
    end
})

-- Refresh button
QuickSection:AddButton({
    Title = "Refresh Connection",
    Description = "Re-check emote folder connection",
    Callback = function()
        local folder = getEmotesFolder()
        if folder then
            local emoteCount = 0
            for _, obj in ipairs(folder:GetDescendants()) do
                if obj:IsA("ModuleScript") then
                    emoteCount = emoteCount + 1
                end
            end
            
            Fluent:Notify({
                Title = "Connected",
                Content = string.format("Found %d emotes available", emoteCount),
                Duration = 3
            })
        else
            Fluent:Notify({
                Title = "Error",
                Content = "Could not connect to emotes folder",
                Duration = 3
            })
        end
    end
})

