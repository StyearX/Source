local InfoSection = EmoteTab:AddSection("━━━ Information ━━━")
InfoSection:AddParagraph({
    Title = "How to Use",
    Content = "1. Enter the emote you OWN in 'Current Emote'\n2. Enter the emote you WANT in 'Swap With'\n3. Click 'Apply Slot' to execute\n\nExample: Current = 'Stride', Swap = 'Broom'\nResult: Broom becomes Stride"
